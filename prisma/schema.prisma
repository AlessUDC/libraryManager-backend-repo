// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  TEACHER
  LIBRARIAN
  ADMINISTRATOR
}

model User {
  userId     String   @id @default(uuid())
  code       String   @unique
  slug       String?  @unique
  password   String
  role       Role     @default(STUDENT)
  isConfirmed Boolean @default(false)
  confirmationToken String?
  tokenExpiration DateTime?
  resendCount Int @default(0)
  
  // Forgot Password fields
  resetPasswordToken String?
  resetPasswordExpires DateTime?
  resetPasswordResendCount Int @default(0)
  lastPasswordReset DateTime?
  
  // Relation to UserData
  userData   UserData @relation(fields: [userDataId], references: [userDataId])
  userDataId String   @unique

  deletedAt DateTime?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Specialized relations
  student       Student?
  teacher       Teacher?
  librarian     Librarian?
  administrator Administrator?
  loans         Loan[]
  reservations  Reservation[]
  fines         Fine[]
  sanctions     Sanction[]
  systemBlockUntil DateTime? 
  loanBlockUntil DateTime?
  appeals         Appeal[] @relation("UserAppeals")
  resolvedAppeals Appeal[] @relation("ResolverAppeals")
}

model UserData {
  userDataId      String   @id @default(uuid())
  name            String
  paternalSurname String
  maternalSurname String
  documentNumber  String   @unique
  maritalStatus   String?
  gender          String?
  activeState     Boolean  @default(true)
  birthdate       DateTime
  mobilePhone     String?
  landlinePhone   String?
  email           String   @unique

  // Relations
  address         Address? @relation(fields: [addressId], references: [addressId])
  addressId       String?
  district        District? @relation(fields: [districtId], references: [districtId])
  districtId      String?

  // Inverse relation to User
  user            User?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Address {
  addressId String     @id @default(uuid())
  title     String
  userData  UserData[]
}

model District {
  districtId String     @id @default(uuid())
  title      String
  userData   UserData[]
  
  // Relation to Province
  province   Province   @relation(fields: [provinceId], references: [provinceId])
  provinceId String
}

model Province {
  provinceId String     @id @default(uuid())
  title      String
  districts  District[]
}

model Faculty {
  facultyId String    @id @default(uuid())
  title     String
  schools   School[]
  teachers  Teacher[]
}

model School {
  schoolId  String    @id @default(uuid())
  title     String
  faculty   Faculty   @relation(fields: [facultyId], references: [facultyId])
  facultyId String
  students  Student[]
}

model Student {
  userId                  String @id
  user                    User   @relation(fields: [userId], references: [userId])
  cycle                   Int
  onTimeDeliveriesCount   Int    @default(0)
  missedReservationsCount Int    @default(0)

  // Relación con School
  school                School @relation(fields: [schoolId], references: [schoolId])
  schoolId              String
}

model Teacher {
  userId    String @id
  user      User   @relation(fields: [userId], references: [userId])

  // Relación con Faculty
  faculty   Faculty @relation(fields: [facultyId], references: [facultyId])
  facultyId String
}

model Librarian {
  userId         String   @id
  user           User     @relation(fields: [userId], references: [userId])
  shift          String
  dateAssignment DateTime @default(now())
}

model Administrator {
  userId         String   @id
  user           User     @relation(fields: [userId], references: [userId])
  dateAssignment DateTime @default(now())
}

enum CopyStatus {
  AVAILABLE
  LENT
  RESERVED
  HELD
  MAINTENANCE
}

enum LoanType {
  HOME
  LIBRARY
}

enum ReservationStatus {
  PENDING
  FULFILLED
  EXPIRED
  CANCELLED
}

enum CopyCondition {
  NEW
  GOOD
  DAMAGED
  LOST
}

model Category {
  categoryId  String   @id @default(uuid())
  title       String
  activeState Boolean  @default(true)
  books       Book[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Author {
  authorId    String   @id @default(uuid())
  name        String
  slug        String?  @unique
  nationality String?
  biography   String?
  activeState Boolean  @default(true)
  books       Book[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Book {
  bookId          String     @id @default(uuid())
  title           String
  slug            String     @unique
  isbn            String?    @unique
  publisher       String?
  publicationYear Int?
  edition         String?
  language        String?
  description     String?
  cost            Float?     @default(0)
  activeState     Boolean    @default(true)
  categories      Category[]
  authors         Author[]
  copies          Copy[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Copy {
  copyId      String        @id @default(uuid())
  barcode     String        @unique
  location    String?
  status      CopyStatus    @default(AVAILABLE)
  condition   CopyCondition @default(NEW)
  activeState Boolean       @default(true)
  book        Book          @relation(fields: [bookId], references: [bookId])
  bookId      String
  loans       Loan[]
  reservations Reservation[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Reservation {
  reservationId        String   @id @default(uuid())

  userId               String
  copyId               String

  token                String   @unique

  requestedLoanType    LoanType
  requestedDueDate     DateTime

  expiresAt            DateTime

  redeemedAt           DateTime?

  failedAttempts       Int      @default(0)

  status               ReservationStatus @default(PENDING)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [userId])
  copy                 Copy     @relation(fields: [copyId], references: [copyId])

  loan                 Loan?
}

enum LoanStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

model Loan {
  loanId               String   @id @default(uuid())

  reservationId        String?  @unique
  reservation          Reservation? @relation(fields: [reservationId], references: [reservationId])

  userId               String
  user                 User     @relation(fields: [userId], references: [userId])
  
  copyId               String
  copy                 Copy     @relation(fields: [copyId], references: [copyId])
  
  borrowDate           DateTime @default(now())
  dueDate              DateTime // This will be the approvedDueDate
  returnDate           DateTime?
  
  type                 LoanType @default(HOME)
  status               LoanStatus @default(ACTIVE)
  observations         String?
  
  depositAmount        Float?    // Cuánto dejó de garantía (2x costo del libro)
  depositStatus        String?   // HELD, REFUNDED, FORFEITED

  fines                Fine[]
  sanctions            Sanction[]
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Fine {
  fineId      String   @id @default(uuid())
  userId      String
  loanId      String
  amount      Float
  description String
  status      FineStatus @default(PENDING) // PENDING, PAID, ANNULLED
  createdAt   DateTime @default(now())
  paidAt      DateTime?

  user        User     @relation(fields: [userId], references: [userId])
  loan        Loan     @relation(fields: [loanId], references: [loanId])
  appeals     Appeal[]
}

model Sanction {
  sanctionId  String   @id @default(uuid())
  userId      String
  loanId      String
  type        SanctionType // LEVE, GRAVE, MUY_GRAVE
  status      SanctionStatus @default(PENDING) // PENDING means it is waiting to accumulate for a block
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [userId])
  loan        Loan     @relation(fields: [loanId], references: [loanId])
  appeals     Appeal[]
}

enum SanctionStatus {
  PENDING
  APPLIED
  REDEEMED
}

enum FineStatus {
  PENDING
  PAID
  ANNULLED
}

enum SanctionType {
  LEVE
  GRAVE
  MUY_GRAVE
}

enum AppealStatus {
  PENDING
  APPROVED
  REJECTED
}

model Appeal {
  appealId    String       @id @default(uuid())
  userId      String
  user        User         @relation("UserAppeals", fields: [userId], references: [userId])
  fineId      String?
  fine        Fine?        @relation(fields: [fineId], references: [fineId])
  sanctionId  String?
  sanction    Sanction?    @relation(fields: [sanctionId], references: [sanctionId])
  reason      String       
  status      AppealStatus @default(PENDING)
  resolverId  String?      
  resolver    User?        @relation("ResolverAppeals", fields: [resolverId], references: [userId])
  resolution  String?      
  createdAt   DateTime     @default(now())
  resolvedAt  DateTime?
}

model AuditLog {
  auditLogId  String   @id @default(uuid())
  action      String   
  entity      String   
  entityId    String?  
  performedBy String   
  details     String?  
  createdAt   DateTime @default(now())
}
